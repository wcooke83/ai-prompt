{
  "manifest_version": 3,
  "name": "AI Provider Automator",
  "version": "2.0.0",
  "description": "Automates AI chat providers via WebSocket commands",
  "key": "",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "nativeMessaging",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://claude.ai/*",
    "*://grok.com/*",
    "*://grok.x.ai/*",
    "*://x.com/*",
    "*://chat.deepseek.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://grok.com/*",
        "*://grok.x.ai/*",
        "*://x.com/i/grok*",
        "*://claude.ai/*",
        "*://chat.deepseek.com/*"
      ],
      "js": [
        "logging.js",
        "providers/index.js",
        "providers/chatgpt.js",
        "providers/grok.js",
        "providers/claude.js",
        "providers/deepseek.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background-sw.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Provider Automator"
  }
}
