# AI-Prompt CLI Configuration

# WebSocket port (default: 8760)
AI_PROMPT_PORT=8760

# Response timeout in seconds (default: 120)
AI_PROMPT_TIMEOUT=120

# Enable logging of WebSocket messages to files (default: false)
AI_PROMPT_LOG_ENABLED=true

# Directory for log files (default: ./logs)
AI_PROMPT_LOG_DIR=./logs

# Default AI provider: chatgpt, claude, grok (optional)
AI_PROMPT_DEFAULT_PROVIDER=
